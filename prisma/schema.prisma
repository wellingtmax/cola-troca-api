generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum AuthProvider {
  LOCAL
  GOOGLE
  FACEBOOK
  PHONE
}

enum TradeStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELED
}

enum StickerRarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

model User {
  id String @id @default(uuid())

  tradeCode String? @unique

  name     String
  nickname String?

  email String? @unique
  phone String? @unique

  passwordHash String?

  provider AuthProvider @default(LOCAL)

  avatarUrl String?

  coins Int @default(500)

  // ========================
  // ENDEREÇO ENTREGA
  // =========================

  zipCode    String?
  street     String?
  number     String?
  complement String?
  district   String?
  city       String?
  state      String?
  country    String? @default("Brasil")

  // =========================
  // PERFIL
  // =========================

  bio String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  albums    UserAlbum[]
  stickers  UserSticker[]
  purchases Purchase[]

  sentTrades     Trade[] @relation("TradeSender")
  receivedTrades Trade[] @relation("TradeReceiver")
}

model Album {
  id String @id @default(uuid())

  themeName String
  coverUrl  String
  price     Float

  company    String  @default("Geral")
  category   String  @default("Geral")
  collection String?

  isFeatured  Boolean @default(false)
  isExclusive Boolean @default(false)

  releaseDate DateTime
  createdAt   DateTime @default(now())

  userStickers UserSticker[]
  stickers     Sticker[]
  userAlbums   UserAlbum[]
  purchases    Purchase[]
}

model Sticker {
  id        String        @id @default(uuid())
  albumId   String
  number    Int
  name      String
  rarity    StickerRarity
  imageUrl  String        @db.Text
  isSpecial Boolean       @default(false)

  album Album @relation(fields: [albumId], references: [id])

  users UserSticker[]

  @@unique([albumId, number])
}

model Pack {
  id              String   @id @default(uuid())
  name            String
  stickerQuantity Int
  price           Float
  createdAt       DateTime @default(now())

  purchases Purchase[]
}

model UserAlbum {
  id         String   @id @default(uuid())
  userId     String
  albumId    String
  acquiredAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  album Album @relation(fields: [albumId], references: [id])

  @@unique([userId, albumId])
}

model UserSticker {
  id String @id @default(uuid())

  userId    String
  stickerId String
  albumId   String

  tradeItems TradeItem[]

  quantityOwned     Int @default(1)
  quantityDuplicate Int @default(0)

  isPlaced Boolean @default(false)

  favorite Boolean @default(false)

  obtainedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  sticker Sticker @relation(fields: [stickerId], references: [id])

  album Album @relation(fields: [albumId], references: [id])

  @@unique([userId, stickerId])
}

model Purchase {
  id      String  @id @default(uuid())
  userId  String
  albumId String?
  packId  String?

  totalValue Float

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  album Album? @relation(fields: [albumId], references: [id])

  pack Pack? @relation(fields: [packId], references: [id])
}

model Trade {
  id String @id @default(uuid())

  senderId   String
  receiverId String

  status TradeStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sender   User @relation("TradeSender", fields: [senderId], references: [id])
  receiver User @relation("TradeReceiver", fields: [receiverId], references: [id])

  items TradeItem[]
}

model TradeItem {
  id String @id @default(uuid())

  tradeId       String
  userStickerId String

  fromUserId String
  toUserId   String

  trade       Trade       @relation(fields: [tradeId], references: [id])
  userSticker UserSticker @relation(fields: [userStickerId], references: [id])
}
