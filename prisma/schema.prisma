generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum AuthProvider {
  LOCAL
  GOOGLE
  FACEBOOK
  PHONE
}

enum TradeStatus {
  PENDING
  COUNTERED
  ACCEPTED
  REJECTED
  CANCELED
}

enum StickerRarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

enum PackType {
  FREE
  SMALL
  MEDIUM
  LARGE
}

enum ChatScope {
  GLOBAL
  COUNTRY
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELED
}

enum NotificationType {
  FRIEND_REQUEST
  CHAT_REPLY
  CHAT_MENTION
  TRADE_RECEIVED
  TRADE_ACCEPTED
  TRADE_REJECTED
  SYSTEM
}

model User {
  id String @id @default(uuid())

  tradeCode String? @unique

  name     String
  nickname String?

  email String? @unique
  phone String? @unique

  passwordHash String?

  provider AuthProvider @default(LOCAL)

  avatarUrl String?

  coins Int @default(500)

  // ========================
  // ENDEREÇO ENTREGA
  // =========================

  zipCode    String?
  street     String?
  number     String?
  complement String?
  district   String?
  city       String?
  state      String?
  country    String? @default("Brasil")

  // =========================
  // PERFIL
  // =========================

  bio String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lastSeenAt DateTime?

  albums    UserAlbum[]
  stickers  UserSticker[]
  purchases Purchase[]

  sentTrades     Trade[] @relation("TradeSender")
  receivedTrades Trade[] @relation("TradeReceiver")
  // ======================================
  // chat
  // ======================================

  chatMessages  ChatMessage[]
  chatLikes     ChatMessageLike[]
  notifications Notification[]

  dismissedChatInteractions ChatInteractionDismissed[]

  sentFriendRequests     FriendRequest[] @relation("FriendRequestSender")
  receivedFriendRequests FriendRequest[] @relation("FriendRequestReceiver")

  friendshipsA Friendship[] @relation("FriendshipUserA")
  friendshipsB Friendship[] @relation("FriendshipUserB")

  featuredStickers UserFeaturedSticker[]
}

model Album {
  id String @id @default(uuid())

  themeName String
  coverUrl  String
  price     Float

  company    String  @default("Geral")
  category   String  @default("Geral")
  collection String?

  isFeatured  Boolean @default(false)
  isExclusive Boolean @default(false)

  releaseDate DateTime
  createdAt   DateTime @default(now())

  userStickers UserSticker[]
  stickers     Sticker[]
  userAlbums   UserAlbum[]
  purchases    Purchase[]
}

model Sticker {
  id        String        @id @default(uuid())
  albumId   String
  number    Int
  name      String
  rarity    StickerRarity
  imageUrl  String        @db.Text
  isSpecial Boolean       @default(false)

  album Album @relation(fields: [albumId], references: [id])

  users UserSticker[]

  @@unique([albumId, number])
}

model Pack {
  id   String @id @default(uuid())
  name String

  type PackType @default(SMALL)

  stickerQuantity Int
  price           Float

  commonChance    Float @default(100)
  rareChance      Float @default(0)
  epicChance      Float @default(0)
  legendaryChance Float @default(0)

  guaranteedLegendary Boolean @default(false)
  dailyLimit          Boolean @default(false)

  createdAt DateTime @default(now())

  purchases Purchase[]
}

model UserAlbum {
  id         String   @id @default(uuid())
  userId     String
  albumId    String
  acquiredAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  album Album @relation(fields: [albumId], references: [id])

  @@unique([userId, albumId])
}

model UserSticker {
  id String @id @default(uuid())

  userId    String
  stickerId String
  albumId   String

  tradeItems TradeItem[]

  quantityOwned     Int @default(1)
  quantityDuplicate Int @default(0)

  isPlaced Boolean @default(false)

  favorite Boolean @default(false)

  obtainedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  sticker Sticker @relation(fields: [stickerId], references: [id])

  album Album @relation(fields: [albumId], references: [id])

  featuredByUsers UserFeaturedSticker[]

  @@unique([userId, stickerId])
}

model Purchase {
  id      String  @id @default(uuid())
  userId  String
  albumId String?
  packId  String?

  totalValue Float

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  album Album? @relation(fields: [albumId], references: [id])

  pack Pack? @relation(fields: [packId], references: [id])
}

model Trade {
  id String @id @default(uuid())

  senderId   String
  receiverId String

  status TradeStatus @default(PENDING)

  senderAccepted   Boolean @default(false)
  receiverAccepted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sender   User @relation("TradeSender", fields: [senderId], references: [id])
  receiver User @relation("TradeReceiver", fields: [receiverId], references: [id])

  items TradeItem[]
}

model TradeItem {
  id String @id @default(uuid())

  tradeId       String
  userStickerId String

  fromUserId String
  toUserId   String

  trade       Trade       @relation(fields: [tradeId], references: [id])
  userSticker UserSticker @relation(fields: [userStickerId], references: [id])
}

model ChatMessage {
  id String @id @default(uuid())

  userId String

  content String @db.Text

  scope ChatScope @default(GLOBAL)

  country String? @default("BR")

  replyToId String?

  isPinned  Boolean @default(false)
  isEdited  Boolean @default(false)
  isDeleted Boolean @default(false)

  imageUrl String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  replyTo ChatMessage?  @relation("MessageReplies", fields: [replyToId], references: [id])
  replies ChatMessage[] @relation("MessageReplies")

  likes ChatMessageLike[]

  dismissedByUsers ChatInteractionDismissed[]

  @@index([scope])
  @@index([country])
  @@index([createdAt])
}

model ChatMessageLike {
  id String @id @default(uuid())

  userId    String
  messageId String

  createdAt DateTime @default(now())

  user    User        @relation(fields: [userId], references: [id])
  message ChatMessage @relation(fields: [messageId], references: [id])

  @@unique([userId, messageId])
}

model FriendRequest {
  id String @id @default(uuid())

  senderId   String
  receiverId String

  status FriendRequestStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sender   User @relation("FriendRequestSender", fields: [senderId], references: [id])
  receiver User @relation("FriendRequestReceiver", fields: [receiverId], references: [id])

  @@unique([senderId, receiverId])
}

model Friendship {
  id String @id @default(uuid())

  userAId String
  userBId String

  createdAt DateTime @default(now())

  userA User @relation("FriendshipUserA", fields: [userAId], references: [id])
  userB User @relation("FriendshipUserB", fields: [userBId], references: [id])

  @@unique([userAId, userBId])
}

model UserFeaturedSticker {
  id String @id @default(uuid())

  userId        String
  userStickerId String

  position Int

  createdAt DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id])
  userSticker UserSticker @relation(fields: [userStickerId], references: [id])

  @@unique([userId, position])
}

model ChatInteractionDismissed {
  id String @id @default(uuid())

  userId    String
  messageId String

  createdAt DateTime @default(now())

  user    User        @relation(fields: [userId], references: [id])
  message ChatMessage @relation(fields: [messageId], references: [id])

  @@unique([userId, messageId])
}

model Notification {
  id String @id @default(uuid())

  userId String

  type NotificationType

  title   String
  message String @db.Text

  linkUrl String?

  isRead Boolean @default(false)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}
